# =========================================================
# MYSQL ROOT USER
# =========================================================
# Root password used by the MySQL container.
# This value is only for local Docker usage.
MYSQL_ROOT_PASSWORD=change-this-root-password


# =========================================================
# APPLICATION DATABASE USER
# =========================================================
# User used by the Spring Boot microservices to connect to MySQL.
APPLIANCE_DB_USERNAME=appliance_app
APPLIANCE_DB_PASSWORD=change-this-app-password


# =========================================================
# DEBEZIUM DATABASE USER
# =========================================================
# User used by Kafka Connect / Debezium to read the MySQL binlog.
DEBEZIUM_DB_USER=debezium
DEBEZIUM_DB_PASSWORD=change-this-debezium-password


# =========================================================
# SPRING CLOUD CONFIG SERVER
# =========================================================
# GitHub repository used by Config Server to load centralized configuration.
# Replace "your-user" with your real GitHub username or organization.
CONFIG_REPO_URI=https://github.com/your-user/appliance-store-config

# Branch used by Config Server.
CONFIG_REPO_BRANCH=main